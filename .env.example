# WalletConnect Project ID
# Get yours at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Pimlico API Configuration
# Get your API key at https://dashboard.pimlico.io/
NEXT_PUBLIC_PIMLICO_API_KEY=

# Optional: Full bundler URL (if you want to customize)
# Leave empty to use default Pimlico endpoint with API key
# NEXT_PUBLIC_PIMLICO_BUNDLER_URL=

# Agora Configuration (for voice calls)
# Get your App ID at https://console.agora.io/
NEXT_PUBLIC_AGORA_APP_ID=

# Optional: Token endpoint for production (leave empty for testing mode)
# NEXT_PUBLIC_AGORA_TOKEN_ENDPOINT=

# Supabase Configuration (for friends list sync and call signaling)
# Get your credentials at https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for server-side operations like phone verification)
# Found in Project Settings > API > service_role key (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=

# Twilio Configuration (for SMS phone verification)
# Get your credentials at https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# The Graph API Key (for ENS resolution)
# Get your key at https://thegraph.com/studio/apikeys/
NEXT_PUBLIC_GRAPH_API_KEY=

# ENS spritz.eth subnames (optional)
# Set to "true" to block passkey / email smart-account users from claiming until Spritz Wallet is GA (EOA only).
# ENS_SUBNAME_EOA_ONLY=true

# Twilio Verify Service SID (recommended for US phone verification)
# Create at: https://console.twilio.com/us1/develop/verify/services
TWILIO_VERIFY_SERVICE_SID=

# The Grid API (all agents get The Grid GraphQL tool)
# See https://docs.thegrid.id/p/Q6EWCrHLq98qF5/Using-the-API
GRID_GRAPHQL_URL=
GRID_API_KEY=
GRID_MCP_SERVER_URL=

# Spotify API (enables search in profile Spotify widget)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google Places API Key (for location-based chat rooms)
# Get your key at https://console.cloud.google.com/apis/credentials
# Enable the "Places API (New)" in the Google Cloud Console
GOOGLE_PLACES_API_KEY=

# Optional: override Solana RPC for server-side SNS (.sol) resolution (/api/sns/resolve).
# Default: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=

# -----------------------------------------------------------------------------
# Keys referenced in application code (placeholders only — never commit real values)
# -----------------------------------------------------------------------------

# Session / auth (server)
SESSION_SECRET=
NEXTAUTH_SECRET=
EMAIL_AUTH_SECRET=

# App URLs
NEXT_PUBLIC_APP_URL=
API_URL=

# Redis (Upstash — rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend)
RESEND_API_KEY=

# Google OAuth / Calendar (cron refresh, scheduling)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# AI (Gemini — agents, knowledge, scraping)
GOOGLE_GEMINI_API_KEY=

# The Graph (token API — wallet transactions / indexing)
GRAPH_TOKEN_API_KEY=

# GitHub (issues, admin bug reports)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# Firecrawl (web indexing for agent knowledge)
FIRECRAWL_API_KEY=

# x402 / payments
PRIVATE_KEY=
X402_FACILITATOR_URL=

# Bundler / RPC
NEXT_PUBLIC_DRPC_API_KEY=
DRPC_API_KEY=
PIMLICO_API_KEY=
NEXT_PUBLIC_PIMLICO_SPONSORSHIP_POLICY_ID=

# Solana / Helius / Alchemy (optional)
NEXT_PUBLIC_HELIUS_API_KEY=
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Huddle01 (calls / rooms)
HUDDLE01_API_KEY=
NEXT_PUBLIC_HUDDLE01_PROJECT_ID=

# Livepeer / streaming
LIVEPEER_API_KEY=

# IPFS / Pinata (pixel art uploads)
PINATA_API_KEY=
PINATA_SECRET_KEY=
NEXT_PUBLIC_PINATA_GATEWAY=

# POAP (channel join)
POAP_API_KEY=

# Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Internal APIs
INTERNAL_API_KEY=
ADMIN_SECRET=
ADMIN_RECOVERY_SECRET=

# Cron (protect /api/cron/*)
CRON_SECRET=

# CDP / Coinbase (if used)
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# Observability / logging
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=
LOGTAIL_SOURCE_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=
NEXT_PUBLIC_LOG_LEVEL=
SERVICE_NAME=

# Grid / agents pricing (optional)
AGENT_COST_INPUT_PER_1M=
AGENT_COST_OUTPUT_PER_1M=

# Giphy widget
NEXT_PUBLIC_GIPHY_API_KEY=

# World ID
NEXT_PUBLIC_WORLD_ID_APP_ID=
NEXT_PUBLIC_WORLD_ID_ACTION=

# Alien SSO
NEXT_PUBLIC_ALIEN_SSO_BASE_URL=
NEXT_PUBLIC_ALIEN_PROVIDER_ADDRESS=

# WebAuthn
NEXT_PUBLIC_WEBAUTHN_RP_ID=

# Events / scripts (cleanup tools — set only when running scripts)
DELETE=
MERGE=
MAX_DAYS_APART=

# -----------------------------------------------------------------------------
# Optional — referenced in src/lib/env.ts schema but not always in code paths
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AGORA_APP_CERTIFICATE=
# AGORA_APP_ID=
# WORLDCOIN_APP_ID=
# NEXT_PUBLIC_WORLDCOIN_APP_ID=
# ADMIN_ADDRESSES=

# -----------------------------------------------------------------------------
# Vercel / Node (usually set by the platform — do not put secrets in repo)
# -----------------------------------------------------------------------------
# NODE_ENV=development
# VERCEL_ENV=
# VERCEL_URL=
# VERCEL_GIT_COMMIT_SHA=

# -----------------------------------------------------------------------------
# Smart contracts (see also contracts/.env.example)
# -----------------------------------------------------------------------------
# MAINNET_RPC_URL=
# ETH_PRIVATE_KEY=
# ETHERSCAN_API_KEY=
# ENS_RESOLVER_ADDR=
