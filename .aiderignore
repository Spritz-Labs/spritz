# Env, cloud & IaC secret patterns — synced: .aiderignore .claudeignore .codeiumignore .continueignore .copilotignore .cursorignore
# (Bulk / non-secret patterns at bottom reduce AI context size only.)

# Environment & direnv
.env
.env.*
!.env.example
!.env.sample
!**/.env.example
!**/.env.sample
.envrc
.direnv/

# Terraform / OpenTofu
.terraform/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example
!**/*.tfvars.example
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Google Cloud / GCP
*-service-account*.json
*service-account*.json
gcloud-service-key*.json
google-credentials.json
google-services.json
GoogleService-Info.plist
application_default_credentials.json
.gcloud/
*-gcp-key*.json

# Kubernetes
kubeconfig
*-kubeconfig
*.kubeconfig
kube_config
kubeconfig.yaml
kubeconfig.yml
**/kubeconfig.local

