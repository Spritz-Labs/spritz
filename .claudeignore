# “Secrets” here = env-variable-style files (+ direnv). Everything else is bulk / noise for AI context.
# Keep in sync: .cursorignore, .copilotignore, .continueignore, .aiderignore, .codeiumignore

# Env-style files (do not index or send to AI)
.env
.env.*
!.env.example
!.env.sample
!**/.env.example
!**/.env.sample
.envrc
.direnv/

# Generated & bulky (not secrets; keeps context small)
node_modules/
.pnp/
.pnp.js
.yarn/
.next/
out/
build/
dist/
.turbo/
coverage/
.nyc_output/
*.tsbuildinfo
supabase/.temp/

audit/
audit-*/
*.zip
*.tar.gz
*.tgz

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.DS_Store
