# Test scripts secrets (explicit; also covered by .env rules below)
scripts/.env

# Dependencies
node_modules/
.pnp/
.pnp.js
.yarn/

# Build outputs
.next/
out/
build/
dist/

# Environment variables & local secrets — never commit
.env
.env.*
!.env.example
!.env.sample
!**/.env.example
!**/.env.sample
# direnv / local shell env (often holds secrets)
.envrc
.direnv/

# Keys, certs, and cloud credential files
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
*-credentials.json
*credentials*.json
service-account*.json
google-services.json
GoogleService-Info.plist
.secrets/
secrets/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE and editor directories
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/
.nyc_output/

# Supabase CLI cache (regenerated by supabase link / start)
supabase/.temp/

# Misc
# Vercel: keep project link so `npm run vercel` targets production (shout → app.spritz.chat)
.vercel/*
!.vercel/project.json
.turbo

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map

# Security Audits
/audit/*
/audit-*