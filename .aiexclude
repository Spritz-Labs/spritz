# Synced: .cursorignore .cursorindexingignore .aiexclude .claudeignore .copilotignore .continueignore .aiderignore .codeiumignore
# Canonical secret rules also live in .gitignore (repo-wide Git). Keep these aligned when editing.

# Environment & direnv
.env
.env.*
!.env.example
!.env.sample
!**/.env.example
!**/.env.sample
.envrc
.direnv/

# Terraform / OpenTofu (keep .terraform.lock.hcl committed)
.terraform/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example
!**/*.tfvars.example
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Google Cloud / GCP
*-service-account*.json
*service-account*.json
gcloud-service-key*.json
google-credentials.json
google-services.json
GoogleService-Info.plist
application_default_credentials.json
.gcloud/
.gcp/
*-gcp-key*.json

# Kubernetes
kubeconfig
*-kubeconfig
*.kubeconfig
kube_config
kubeconfig.yaml
kubeconfig.yml
**/kubeconfig.local
helm-secrets/

# AWS
.aws/credentials
.aws/config
aws-credentials.csv
aws_access_keys.txt

# Azure
*.publishsettings
*.azurePubxml
azureProfile.json
.azure/
azure.auth

# Keys, certs, dumps
*.pem
*.p12
*.pfx
*.crt
*.cer
*.csr
*.jks
*.ppk
*.key
!*.public.key
!**/*.pub
id_rsa
id_ecdsa
id_ed25519
known_hosts
known_hosts.bak
*-credentials.json
credentials.json
!credentials.example.json
.secrets/

# App / framework secret filenames
secrets.json
!secrets.example.json
config/secrets.yml
secrets.yml
!secrets.example.yml
/secrets.yaml
/secrets.yml
database.yml
!database.yml.example
local_settings.py
settings_local.py
application-local.properties
*.secret
!*.secret.example

# SOPS / decrypted
*.decrypted.*
*.decrypted~

# HashiCorp Vault
vault-token
.vault-token

# CI / package auth overlays
.sentryclirc
.npmrc.local
.pypirc
.gem/credentials

# Generated env shims
*.env.js
*.env.cjs
*.env.mjs
generated-secrets.*

# Docker
.docker/config.json

# Netrc
.netrc

# Vercel CLI (local tokens)
.vercel/

