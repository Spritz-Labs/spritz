# RPC — use Ethereum mainnet for ENS (Spritz resolver must be on chain id 1)
# dRPC: https://drpc.org/docs/ethereum-api
#   Public (no key):  https://eth.drpc.org/
#   API key (higher limits): https://lb.drpc.live/ethereum/YOUR_DRPC_API_KEY
MAINNET_RPC_URL=https://eth.drpc.org/

# EIP-3668 gateway — must include {sender} and {data} literals for ENS clients
SPRITZ_ENS_GATEWAY_URL=https://app.spritz.chat/api/ens/ccip-gateway?sender={sender}&data={data}

# --- Signer for `forge script --broadcast` (pick one) ---
#
# 1) Hot wallet (simplest): set this in contracts/.env, then from repo root:
#      cd contracts && set -a && source .env && set +a && forge script ...
#    Or export in your shell before running npm run contracts:deploy:ens-resolver*
#    Foundry looks for ETH_PRIVATE_KEY (or PRIVATE_KEY in many versions).
#
ETH_PRIVATE_KEY=0xYOUR_MAINNET_DEPLOYER_PRIVATE_KEY

# 2) No key in file: omit the line above and pass once:
#    ETH_PRIVATE_KEY=0x... forge script ... --broadcast
#
# 3) Hardware wallet / keystore: do not set ETH_PRIVATE_KEY; use Ledger or
#    `cast wallet import` + forge --account NAME (see contracts/README.md).
#
# Never commit contracts/.env — it is ignored by git like other .env files.
