# RPC — Ethereum mainnet for ENS
# dRPC: https://drpc.org/docs/ethereum-api
MAINNET_RPC_URL=https://eth.drpc.org/

# Quote this value — `&` breaks `source .env` if unquoted
SPRITZ_ENS_GATEWAY_URL='https://app.spritz.chat/api/ens/ccip-gateway?sender={sender}&data={data}'

# Hot-wallet deployer (becomes resolver `owner`). For broadcast, Foundry often needs:
#   --private-key "$ETH_PRIVATE_KEY"
ETH_PRIVATE_KEY=0xYOUR_KEY

# Optional: verify on Etherscan (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=

# Address printed after deploy (for npm run contracts:verify:ens-resolver)
ENS_RESOLVER_ADDR=0xYourDeployedSpritzENSResolver
