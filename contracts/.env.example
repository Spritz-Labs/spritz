# RPC — use Ethereum mainnet for ENS (Spritz resolver must be on chain id 1)
# dRPC: https://drpc.org/docs/ethereum-api
#   Public (no key):  https://eth.drpc.org/
#   API key (higher limits): https://lb.drpc.live/ethereum/YOUR_DRPC_API_KEY
MAINNET_RPC_URL=https://eth.drpc.org/

# EIP-3668 gateway — must include {sender} and {data} literals for ENS clients
SPRITZ_ENS_GATEWAY_URL=https://app.spritz.chat/api/ens/ccip-gateway?sender={sender}&data={data}

# Forge broadcast (choose one approach)
# Private key (hot wallet) — forge uses ETH_PRIVATE_KEY or pass --private-key
# ETH_PRIVATE_KEY=0x...
